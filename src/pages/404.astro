---
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

const meta = {
  description: 'Not found',
  title: '404'
}

const path = Astro.url.pathname
---

<PageLayout {meta} highlightColor='#D0342C'>
  <div class='px-4 py-10 text-center sm:px-6 lg:px-8'>
    <h1 class='block text-7xl font-bold sm:text-9xl'>404</h1>
    <p class='mt-3 text-muted-foreground'>Ú oà, có gì đó đã xảy ra.</p>
    <p class='text-lg'>Xin lỗi, trang {path} không tồn tại.</p>
    <Button title='Trở về trang chủ' href='/' variant='ahead' class='mt-5' />
  </div>
</PageLayout>
