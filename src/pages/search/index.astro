---
import { PFSearch } from 'astro-pure/components/pages'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import { integ } from '@/site-config'

const meta = {
  description: 'Search relative posts of the whole blog',
  title: 'Tìm kiếm'
}
---

<PageLayout {meta}>
  <Button title='Trở về' href='/blog' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>Tìm kiếm</h1>
    </div>

    <div id='content' class='animate'>
      {
        integ.pagefind ? (
          <>
            <p>Nhập từ hoặc cụm từ để tìm kiếm bài viết.</p>
            <PFSearch />
          </>
        ) : (
          <p>Trang tìm kiếm không hoạt động.</p>
        )
      }
    </div>
  </main>
</PageLayout>
